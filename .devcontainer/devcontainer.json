{
	"name": "Spacesuits dev container - demo 2",
	"image": "node:22",
	"features": {
		"ghcr.io/devcontainers-extra/features/angular-cli:2": {},
		"ghcr.io/devcontainers/features/docker-in-docker:2": {}
	},
	"postCreateCommand": {
		"InstallDeps": "cd front/spacesuit-status-front && npm i",
		"StartServicesCompose": "docker-compose up -d",
		"StartServiceMockoon": "docker run -d --mount type=bind,source=../front/mocks/backend-mocks.json,target=/data,readonly -p 3001:3000 mockoon/cli:9 --data data --port 3000"
	},
	"forwardPorts": [ 4200, 8080, 3000 ],
	"customizations": {
	  "vscode": {
		"settings": {
		  "editor.tabSize": 2
		},
		"extensions": [
		  "Angular.ng-template"
		]
	  }
	}
}